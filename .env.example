# Ornek ortam degiskenleri sablonu.
# Bu dosyayi kopyalayip ".env" olarak kaydedin ve degerleri doldurun.

# PostgreSQL (Docker)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Uygulamanin veritabanina baglanma adresi (calisma zamani).
# Yerelde: postgresql://KULLANICI:SIFRE@localhost:5432/VERITABANI?schema=public
# Vercel + Neon/Supabase'de: pooler (pgbouncer) URL'i kullanin.
DATABASE_URL=

# Migration'lar icin DOGRUDAN baglanti (prisma migrate bunu kullanir).
# Pooler kullanmayan ortamlarda (yerel/CI) DATABASE_URL ile ayni degeri verin.
# Neon/Supabase'de "direct connection" (pooler olmayan) URL'i kullanin.
DIRECT_URL=

# Auth.js oturum imzalama anahtari
# Uretmek icin: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Bos veritabaninda olusturulacak ilk yonetici (idempotent bootstrap).
# Kayit yalnizca ADMIN'e acik oldugundan ilk giris icin gereklidir.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# E-posta bildirimleri (gunluk cron). Hepsi opsiyoneldir; RESEND_API_KEY yoksa
# gonderim atlanir (uygulama yine calisir).
# Resend API anahtari: https://resend.com
RESEND_API_KEY=
# Gonderen adres (uretimde dogrulanmis alan adi). Ornek: "Ciftlik Pro <uyari@alanadi.com>"
ALERT_EMAIL_FROM=
# Cron ucnoktasini korur. Vercel Cron bu deger tanimliysa Authorization basligini otomatik ekler.
CRON_SECRET=

# Magaza odemesi (Stripe) — opsiyonel. STRIPE_SECRET_KEY yoksa magaza "odeme
# teslimatta" akisinda calisir. Tanimliysa Stripe Checkout devreye girer.
# Anahtarlar: https://dashboard.stripe.com/apikeys (test modu icin "sk_test_...")
STRIPE_SECRET_KEY=
# Webhook imza dogrulama sirri: stripe webhook (checkout.session.completed) icin.
# https://dashboard.stripe.com/webhooks -> endpoint: /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# Stripe redirect URL'leri icin uygulama adresi (opsiyonel; yoksa istek origin'i).
NEXT_PUBLIC_SITE_URL=
