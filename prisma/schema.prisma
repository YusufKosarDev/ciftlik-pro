// Prisma sema dosyasi
// Dokumantasyon: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Uygulama calisma zamani baglantisi. Serverless (Vercel) + Neon/Supabase'de
  // bu, pooler (pgbouncer) uzerinden gelen HAVUZLANMIS baglanti olmalidir.
  url       = env("DATABASE_URL")
  // Migration'lar (prisma migrate) icin DOGRUDAN baglanti. Pooler migration'lari
  // desteklemedigi icin ayri tutulur. Pooler kullanmayan ortamlarda (yerel/CI)
  // DATABASE_URL ile ayni degeri verin.
  directUrl = env("DIRECT_URL")
}

// Abonelik plani (SaaS).
enum Plan {
  FREE
  PRO
}

// Kiraci (tenant) — her tenant bir ciftlik/isletmedir. Cok-kiracilik Faz 1:
// backfill + NOT NULL + per-tenant unique + Postgres RLS tamamlandi. "tenantId"
// 17 veri tablosunda zorunludur; AuditLog (sistem kayitlari icin nullable) ve
// Order/OrderItem (per-tenant vitrin Faz 4'e kadar) nullable kalir.
model Tenant {
  id        String   @id @default(cuid())
  name      String // Ciftlik/isletme adi
  slug      String   @unique // acme (subdomain/URL icin, ileride)
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
}

// Kullanici rolleri (RBAC)
enum Role {
  ADMIN // Yonetici: her seye tam erisim
  WORKER // Calisan: hayvan/tarla/stok gunluk islemleri
  VET // Veteriner: saglik, asi, tedavi
  ACCOUNTANT // Muhasebeci: finans, gelir-gider, satis
}

// Denetim kaydi islem turu
enum AuditAction {
  CREATE // Olusturma
  UPDATE // Guncelleme
  DELETE // Silme
  LOGIN_FAILED // Basarisiz giris denemesi (guvenlik izi)
}

// Denetim gunlugu: kim, neyi, ne zaman degistirdi (yazma islemleri).
model AuditLog {
  id        String      @id @default(cuid())
  tenantId  String?
  actorId   String? // Islemi yapan kullanici id'si (kullanici silinse de kayit kalir)
  actorName String // Snapshot: kullanici adi/e-postasi
  action    AuditAction
  entity    String // Etkilenen varlik (orn. "Animal", "Transaction")
  entityId  String? // Varlik id'si (varsa)
  summary   String? // Insana okunur kisa aciklama
  createdAt DateTime    @default(now())

  @@index([createdAt])
}

// Sistemi kullanan personel
model User {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  email       String    @unique
  password    String // Parolanin hash'lenmis hali saklanir, asla duz metin degil
  role        Role      @default(WORKER)
  onboardedAt DateTime? // Hos geldin turunu tamamladigi an (null ise tur gosterilir)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tasks Task[]
}

// Gorev durumu
enum TaskStatus {
  PENDING // Bekliyor
  IN_PROGRESS // Devam ediyor
  DONE // Tamamlandi
}

// Personele atanan gorev
model Task {
  id           String     @id @default(cuid())
  tenantId     String
  title        String // Gorev basligi
  description  String?
  assignedToId String?
  assignedTo   User?      @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  status       TaskStatus @default(PENDING)
  dueDate      DateTime? // Son tarih
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([assignedToId])
  // Takvim/dashboard/cron son tarih araligi sorgulari icin.
  @@index([dueDate])
}

// Hayvan turleri
enum AnimalSpecies {
  CATTLE // Sigir / inek
  SHEEP // Koyun
  GOAT // Keci
  CHICKEN // Tavuk
  OTHER // Diger
}

// Hayvanin cinsiyeti
enum AnimalGender {
  FEMALE // Disi
  MALE // Erkek
}

// Hayvanin guncel durumu
enum AnimalStatus {
  ACTIVE // Ciftlikte aktif
  SOLD // Satildi
  DECEASED // Oldu
}

// Ciftlikteki hayvanlar
model Animal {
  id        String        @id @default(cuid())
  tenantId  String
  tagNumber String // Kulak kupesi numarasi (tenant icinde benzersiz)
  name      String? // Istege bagli isim/lakap
  species   AnimalSpecies
  breed     String? // Cins/irk (orn. Holstein)
  gender    AnimalGender
  birthDate DateTime?
  status    AnimalStatus  @default(ACTIVE)
  imageUrl  String? // Hayvan gorseli (dis URL)
  notes     String? // Serbest notlar
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Soy/pedigri: anne ayni tablodadir (self-relation). Anne silinirse
  // yavrunun motherId'si null olur (yavru silinmez).
  motherId  String?
  mother    Animal?  @relation("Lineage", fields: [motherId], references: [id], onDelete: SetNull)
  offspring Animal[] @relation("Lineage")

  healthRecords   HealthRecord[]
  vaccinations    Vaccination[]
  milkYields      MilkYield[]
  breedingRecords BreedingRecord[]
  weightRecords   WeightRecord[]

  @@unique([tenantId, tagNumber]) // Kulak numarasi tenant icinde benzersiz
  @@index([motherId])
}

// Bir hayvana ait saglik/tedavi kaydi
model HealthRecord {
  id        String   @id @default(cuid())
  tenantId  String
  animalId  String
  animal    Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  date      DateTime // Muayene/tedavi tarihi
  diagnosis String // Teshis
  treatment String? // Uygulanan tedavi
  notes     String? // Ek notlar
  createdAt DateTime @default(now())

  @@index([animalId])
}

// Bir hayvana yapilan asi kaydi
model Vaccination {
  id        String    @id @default(cuid())
  tenantId  String
  animalId  String
  animal    Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)
  name      String // Asi adi
  date      DateTime // Yapilis tarihi
  nextDate  DateTime? // Sonraki asi tarihi (varsa)
  notes     String?
  createdAt DateTime  @default(now())

  @@index([animalId])
  // Yaklasan asi araligi sorgulari (takvim/dashboard/cron) icin.
  @@index([nextDate])
}

// Finansal islem turu
enum TransactionType {
  INCOME // Gelir
  EXPENSE // Gider
}

// Gelir/gider kaydi
model Transaction {
  id          String          @id @default(cuid())
  tenantId    String
  type        TransactionType
  amount      Float // Tutar (TL)
  category    String // Kategori (orn. Sut satisi, Yem alimi)
  date        DateTime // Islem tarihi
  description String?
  createdAt   DateTime        @default(now())

  @@index([date])
}

// Envanter kategorileri
enum InventoryCategory {
  FEED // Yem
  MEDICINE // Ilac
  EQUIPMENT // Ekipman
  OTHER // Diger
}

// Stok / envanter kalemi
model InventoryItem {
  id            String            @id @default(cuid())
  tenantId      String
  name          String // Kalem adi
  category      InventoryCategory
  quantity      Float // Mevcut miktar
  unit          String // Birim (kg, adet, litre...)
  criticalLevel Float             @default(0) // Kritik seviye (altina dusunce uyari)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  feedLogs FeedLog[]
}

// Bir yem (FEED) kaleminin tuketim kaydi. Tuketim eklendiginde ilgili
// stok kaleminin miktari dusurulur (bkz. POST /api/feed).
model FeedLog {
  id              String        @id @default(cuid())
  tenantId        String
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  date            DateTime // Tuketim tarihi
  quantity        Float // Tuketilen miktar (kalemin birimiyle)
  notes           String?
  createdAt       DateTime      @default(now())

  @@index([inventoryItemId])
}

// Ekim durumu
enum CropStatus {
  PLANTED // Ekildi
  GROWING // Buyuyor
  HARVESTED // Hasat edildi
}

// Ciftlikteki tarlalar
model Field {
  id        String   @id @default(cuid())
  tenantId  String
  name      String // Tarla adi
  area      Float // Alan (donum)
  location  String? // Konum/mevki
  notes     String?
  posX      Float? // 2D harita yatay konumu (sanal birim; null ise otomatik yerlesir)
  posY      Float? // 2D harita dikey konumu (sanal birim; null ise otomatik yerlesir)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  crops Crop[]
}

// Bir tarlaya yapilan ekim/hasat kaydi
model Crop {
  id          String     @id @default(cuid())
  tenantId    String
  fieldId     String
  field       Field      @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  name        String // Urun adi (orn. Bugday)
  plantedDate DateTime // Ekim tarihi
  harvestDate DateTime? // Hasat tarihi (varsa)
  status      CropStatus @default(PLANTED)
  cost        Float? // Ekim gideri (TL)
  revenue     Float? // Hasat geliri (TL)
  yieldAmount Float? // Verim (kg)
  notes       String?
  createdAt   DateTime   @default(now())

  @@index([fieldId])
  // Takvimde hasat tarihi araligi sorgulari icin.
  @@index([harvestDate])
}

// Bir hayvanin gunluk sut verimi kaydi
model MilkYield {
  id        String   @id @default(cuid())
  tenantId  String
  animalId  String
  animal    Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  date      DateTime // Olcum tarihi
  amount    Float // Litre cinsinden miktar
  notes     String?
  createdAt DateTime @default(now())

  @@index([animalId])
}

// Bir hayvanin periyodik agirlik (tartim) kaydi
model WeightRecord {
  id        String   @id @default(cuid())
  tenantId  String
  animalId  String
  animal    Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  date      DateTime // Tartim tarihi
  weightKg  Float // Agirlik (kg)
  notes     String?
  createdAt DateTime @default(now())

  @@index([animalId])
}

// Ureme/gebelik kaydi durumu
enum BreedingStatus {
  PLANNED // Planlandi (tohumlama/ciftlesme yapildi)
  PREGNANT // Gebe
  BORN // Dogum gerceklesti
  FAILED // Basarisiz / dusuk
}

// Bir disi hayvanin ureme/gebelik kaydi
model BreedingRecord {
  id                String         @id @default(cuid())
  tenantId          String
  animalId          String
  animal            Animal         @relation(fields: [animalId], references: [id], onDelete: Cascade)
  sireTag           String? // Baba kulak numarasi (serbest metin; baba sistemde olmayabilir)
  breedingDate      DateTime // Tohumlama/ciftlesme tarihi
  expectedBirthDate DateTime? // Tahmini dogum tarihi
  actualBirthDate   DateTime? // Gercek dogum tarihi
  status            BreedingStatus @default(PLANNED)
  offspringCount    Int? // Yavru sayisi (dogum gerceklestiyse)
  notes             String?
  createdAt         DateTime       @default(now())

  @@index([animalId])
  // Takvimde tahmini dogum tarihi araligi sorgulari icin.
  @@index([expectedBirthDate])
}

// Yapi turleri (2D harita uzerinde gosterilen tesisler)
enum StructureType {
  BARN // Ahir
  COOP // Kumes
  STORAGE // Depo
  OTHER // Diger
}

// Ciftlikteki yapilar (ahir, kumes, depo...) — 2D haritada konumlu
model Structure {
  id        String        @id @default(cuid())
  tenantId  String
  name      String // Yapi adi
  type      StructureType
  posX      Float? // 2D harita yatay konumu (sanal birim)
  posY      Float? // 2D harita dikey konumu (sanal birim)
  width     Float? // Genislik (sanal birim; null ise varsayilan)
  height    Float? // Yukseklik (sanal birim; null ise varsayilan)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// Musteri (alici). Satislar opsiyonel olarak bir musteriye baglanir.
model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String // Musteri adi / unvani
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]
}

// Satis kaydi. Olusturuldugunda otomatik bir gelir (INCOME) islemi uretilir ve
// transactionId ile baglanir; boylece satislar finansa otomatik yansir.
model Sale {
  id            String    @id @default(cuid())
  tenantId      String
  item          String // Satilan (serbest metin: "Sut 100L", "Inek TR-001")
  customerId    String? // Musteri (opsiyonel)
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  quantity      Float? // Miktar (opsiyonel)
  unit          String? // Birim (kg, litre, adet...)
  amount        Float // Toplam tutar (TL)
  date          DateTime // Satis tarihi
  notes         String?
  transactionId String?   @unique // Otomatik olusturulan gelir isleminin id'si
  createdAt     DateTime  @default(now())

  @@index([date])
  @@index([customerId])
}

// Magaza (herkese acik katalog) urunu.
model Product {
  id          String   @id @default(cuid())
  tenantId    String
  name        String // Urun adi
  description String?
  price       Float // Birim fiyat (TL)
  unit        String? // Birim (kg, litre, adet...)
  active      Boolean  @default(true) // Katalogda gosterilsin mi
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
}

// Siparis durumu
enum OrderStatus {
  PENDING // Bekliyor
  CONFIRMED // Onaylandi
  CANCELLED // Iptal
}

// Odeme durumu (gercek odeme yapilandirildiysa kullanilir).
enum PaymentStatus {
  UNPAID // Odemesiz / beklemede
  PAID // Odendi
}

// Magazadan verilen (odemesiz olabilen) siparis. Cok kalemlidir (OrderItem).
model Order {
  id            String        @id @default(cuid())
  tenantId      String?
  customerName  String // Siparis veren ad
  customerPhone String? // Iletisim (opsiyonel)
  note          String?
  total         Float // Kalemlerin toplami (snapshot)
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  paymentRef    String? // Odeme saglayici referansi (orn. Stripe session id)
  createdAt     DateTime      @default(now())

  items OrderItem[]

  @@index([createdAt])
  @@index([status])
}

// Bir siparisteki tek urun satiri. Fiyat/ad anlik snapshot olarak saklanir
// (urun sonradan degisse/silinse de siparis bozulmaz).
model OrderItem {
  id          String   @id @default(cuid())
  tenantId    String?
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String? // Iliskili urun (silinirse null; snapshot kalir)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String // Snapshot: urun adi
  unitPrice   Float // Snapshot: birim fiyat
  quantity    Float // Adet/miktar
  lineTotal   Float // unitPrice * quantity

  @@index([orderId])
  @@index([productId])
}

// Personel daveti (tenant-ici). ADMIN bir e-posta + rol icin davet olusturur;
// davetli, token'li baglantiyla kendi adini/parolasini belirleyip katilir.
//
// NOT: Bu tablo RLS DISIDIR — kabul akisi (public) daveti token ile, oturum/tenant
// baglami OLMADAN okur. Token tahmin edilemez bir sirdir; tenantId yalnizca
// kabul edildiginde olusturulacak User'i dogru tenant'a baglamak ve ADMIN'in
// kendi davetlerini listelemesi (app-katmani filtre) icindir.
model Invitation {
  id          String    @id @default(cuid())
  tenantId    String // Davet eden tenant
  email       String // Davet edilen e-posta
  role        Role      @default(WORKER)
  token       String    @unique // Kabul baglantisindaki sir
  invitedById String? // Daveti olusturan ADMIN (snapshot; iliski tutulmaz)
  expiresAt   DateTime // Bu andan sonra kabul edilemez
  acceptedAt  DateTime? // Kabul edildiyse zaman damgasi (tekrar kullanim engellenir)
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([email])
}
